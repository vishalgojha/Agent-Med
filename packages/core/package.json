{
  "name": "@agent-med/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "agent-med": "./bin/agent-med.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/tests/*.spec.ts",
    "start": "tsx src/index.ts",
    "serve": "tsx src/index.ts serve",
    "init": "tsx src/index.ts init",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.56.0",
    "better-sqlite3": "^12.4.1",
    "commander": "^14.0.1",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "p-queue": "^8.1.0",
    "twilio": "^5.10.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
