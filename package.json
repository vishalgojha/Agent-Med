{
  "name": "agent-med-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:all": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspace=@agent-med/core",
    "start": "npm run start --workspace=@agent-med/core",
    "serve": "npm run serve --workspace=@agent-med/core",
    "init": "npm run init --workspace=@agent-med/core",
    "ui:install": "npm install --prefix packages/ui",
    "ui:dev": "npm run dev --workspace=@agent-med/ui",
    "ui:build": "npm run build --workspace=@agent-med/ui",
    "ui:preview": "npm run preview --workspace=@agent-med/ui",
    "mcp:serve": "npm run start --workspace=@agent-med/mcp-server",
    "mcp:dev": "npm run dev --workspace=@agent-med/mcp-server",
    "a2a:serve": "npm run start --workspace=@agent-med/a2a-agent",
    "a2a:dev": "npm run dev --workspace=@agent-med/a2a-agent"
  }
}
