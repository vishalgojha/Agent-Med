{
  "name": "doctor-agent-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:all": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test": "npm run test --workspace=@doctor-agent/core",
    "start": "npm run start --workspace=@doctor-agent/core",
    "serve": "npm run serve --workspace=@doctor-agent/core",
    "init": "npm run init --workspace=@doctor-agent/core",
    "ui:install": "npm install --prefix packages/ui",
    "ui:dev": "npm run dev --workspace=@doctor-agent/ui",
    "ui:build": "npm run build --workspace=@doctor-agent/ui",
    "ui:preview": "npm run preview --workspace=@doctor-agent/ui"
  }
}
